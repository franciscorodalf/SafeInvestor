<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@../../../styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.franciscorodalf.saveinvestor.frontend.controller.DashboardController">
    <left>
        <VBox alignment="TOP_CENTER" spacing="12" style="-fx-background-color: #ffffff; -fx-padding: 30 20 30 20; -fx-border-color: #dfe6e9; -fx-border-width: 0 1 0 0;">
            <children>
                <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../images/logo-saveInvestor.png" />
                    </image>
                </ImageView>
                <Label text="SafeInvestor" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Button fx:id="btnResumen" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarResumen" styleClass="nav-button" text="Resumen" />
                <Button fx:id="btnHistorial" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarHistorial" styleClass="nav-button" text="Historial" />
                <Button fx:id="btnObjetivos" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarObjetivos" styleClass="nav-button" text="Objetivos" />
                <Button fx:id="btnEstadisticas" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarEstadisticas" styleClass="nav-button" text="Estadísticas" />
                <Button fx:id="btnPortafolio" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarPortafolio" styleClass="nav-button" text="Portafolio" />
                <Button fx:id="btnPerfil" alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onMostrarPerfil" styleClass="nav-button" text="Perfil" />
            </children>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 20 30 20 30; -fx-background-color: rgba(255,255,255,0.8);">
            <children>
                <Label text="Bienvenido," style="-fx-text-fill: #2c3e50; -fx-font-size: 16px;" />
                <Label fx:id="lblUsuario" style="-fx-text-fill: #27ae60; -fx-font-size: 16px; -fx-font-weight: bold;" text="Usuario" />
                <Button mnemonicParsing="false" onAction="#onCerrarSesion" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 20;" text="Cerrar sesión" />
            </children>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentContainer" prefHeight="600.0" prefWidth="820.0" style="-fx-padding: 30; -fx-background-color: rgba(255,255,255,0.7);" />
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 20 15 30;">
            <children>
                <Label fx:id="lblEstado" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;" text="" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
