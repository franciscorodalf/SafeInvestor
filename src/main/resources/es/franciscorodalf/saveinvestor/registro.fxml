<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="root" stylesheets="@../../../styles/modern-theme.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.franciscorodalf.saveinvestor.frontend.controller.RegistroController">
   <children>
      <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" maxWidth="450.0" spacing="15.0" styleClass="container">
               <children>
                  <!-- Título -->
                  <Label fx:id="LabelRegistro" styleClass="label-title" text="Crear Cuenta" />
                  <Label styleClass="label-subtitle" text="Únete a SafeInvestor hoy mismo" />

                  <!-- Formulario -->
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Usuario" styleClass="label" />
                        <TextField fx:id="textFieldUsuarioRegistro" promptText="Nombre de usuario" styleClass="text-field" />
                        
                        <Label text="Correo Electrónico" styleClass="label" />
                        <TextField fx:id="textFieldEmailRegistro" promptText="ejemplo@correo.com" styleClass="text-field" />
                        <TextField fx:id="textFieldRepetirEmail" promptText="Confirmar correo" styleClass="text-field" />
                        
                        <Label text="Contraseña" styleClass="label" />
                        <PasswordField fx:id="textFieldContraseniaRegistro" promptText="Contraseña segura" styleClass="password-field" />
                        <PasswordField fx:id="textFieldRepetirContraseniaRegistro" promptText="Confirmar contraseña" styleClass="password-field" />
                     </children>
                  </VBox>

                  <Label fx:id="textMensajeRegistro" styleClass="error-label" visible="false" wrapText="true" />

                  <!-- Botones -->
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Button fx:id="buttonVolver" onAction="#clickButtonVolver" styleClass="button-secondary" text="Volver" />
                        <Button fx:id="ButtonRegistrarse" defaultButton="true" onAction="#clickRegistrarse" styleClass="button-primary" text="Registrarse" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>

               </children>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
